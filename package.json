{
  "name": "vue-collision",
  "version": "2.0.1",
  "description": "fires a collide/non-collide event on collision with viewport or any other bounding box",
  "type": "module",
  "author": {
    "name": "Marco Boffo",
    "email": "marcoboffo.waves@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scaccogatto/vue-collision.git"
  },
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "vite",
    "collision",
    "intersection",
    "viewport",
    "directive",
    "bounding-box",
    "overlap"
  ],
  "main": "./dist/vue-collision.cjs",
  "module": "./dist/vue-collision.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-collision.js",
      "require": "./dist/vue-collision.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  }
}
